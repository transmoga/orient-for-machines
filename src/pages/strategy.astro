                <tr><td class="k">500 people</td><td><span class="v">$216k ARR</span></td><td><span class="v">$240k–$336k ARR</span></td><td>$240k–$340k</td></tr>
                <tr><td class="k">1,000 people</td><td><span class="v">$432k ARR</span></td><td><span class="v">$492k–$732k ARR</span></td><td>$490k–$730k</td></tr>
              </tbody>
