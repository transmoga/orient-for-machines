---
export const prerender = false;

const next = Astro.url.searchParams.get('next') || '/pricing';
const configured = Boolean(import.meta.env.SITE_PASSWORD);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Orient — Sign in</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/orient.css" />
  <style>
    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: var(--sans, 'IBM Plex Sans', sans-serif);
      background: var(--paper, #f7f4ef);
      color: var(--ink, #262017);
      margin: 0;
      padding: 24px;
    }
    .card {
      width: 100%;
      max-width: 400px;
      background: var(--paper);
      border: 1px solid var(--line, #e5dfd4);
      border-radius: 12px;
      padding: 32px;
    }
    h1 { font-size: 22px; margin: 0 0 8px; font-weight: 600; }
    p { margin: 0 0 24px; color: var(--ink-2, #5c564c); font-size: 14px; line-height: 1.5; }
    label { display: block; font-size: 13px; margin-bottom: 8px; color: var(--ink-2); }
    input {
      width: 100%;
      box-sizing: border-box;
      height: 48px;
      padding: 0 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      font-size: 15px;
      margin-bottom: 16px;
    }
    input:focus { outline: none; border-color: var(--ink); box-shadow: 0 0 0 3px oklch(0.245 0.012 62 / 0.08); }
    button {
      width: 100%;
      height: 48px;
      border: none;
      border-radius: 8px;
      background: var(--ink);
      color: var(--paper);
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
    }
    button:disabled { opacity: 0.6; cursor: not-allowed; }
    .err { color: #b42318; font-size: 13px; margin-top: 12px; min-height: 1.2em; }
    .back { display: inline-block; margin-top: 20px; font-size: 13px; color: var(--ink-3); }
  </style>
</head>
<body>
  <div class="card">
    <h1>Internal access</h1>
    <p>Sign in to view internal materials.</p>
    {!configured ? (
      <p class="err">SITE_PASSWORD is not set. Add it in Vercel env vars to enable access.</p>
    ) : (
      <form id="login-form">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required />
        <button type="submit" id="submit-btn">Continue</button>
        <p class="err" id="error" role="alert"></p>
      </form>
    )}
    <a class="back" href="/">← Back to site</a>
  </div>
  <script define:vars={{ next }}>
    const form = document.getElementById('login-form');
    if (!form) return;
    const errEl = document.getElementById('error');
    const btn = document.getElementById('submit-btn');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errEl.textContent = '';
      btn.disabled = true;
      const password = document.getElementById('password').value;
      try {
        const res = await fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          errEl.textContent = data.error || 'Sign in failed';
          btn.disabled = false;
          return;
        }
        window.location.href = next.startsWith('/') ? next : '/pricing';
      } catch {
        errEl.textContent = 'Network error — try again';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
