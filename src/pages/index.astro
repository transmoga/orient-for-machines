---
export const prerender = true;
import SiteScripts from '../components/SiteScripts.astro';
import Newsletter from '../components/Newsletter.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Orient — The meaning layer for humans and machines</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/orient.css" />
<link rel="stylesheet" href="/landing.css" />
<style>
  /* v2-only: align the two panes — equal headline block, doors pinned to the bottom */
  .split .pane { display: flex; }
  .split .pane .inner { display: flex; flex-direction: column; }
  .split h3 { max-width: 18ch; } /* a wider measure so titles wrap to fewer lines */
  @media (min-width: 861px) {
    .split h3 { min-height: 4.6em; } /* reserve the taller headline so body copy starts level */
  }
  /* v2-only: turn the dual panes into doors */
  .split .pane .door {
    display: inline-flex; align-self: flex-start; align-items: center; gap: 8px;
    margin-top: auto; padding-top: 36px;
    font-family: var(--mono); font-size: 13px; letter-spacing: 0.06em;
    text-decoration: none; transition: gap .15s ease, opacity .15s ease;
  }
  .split .pane .door:hover { gap: 13px; opacity: .8; }
  .split .pane.h .door { color: var(--human); }
  .split .pane.m .door { color: oklch(0.7 0.08 252); }
  .split .pane .door svg { width: 16px; height: 16px; }
  /* v2-only: compressed spine caption */
  .arch .spine-note { margin-top: 30px; font-size: 15px; color: var(--ink-3); font-family: var(--mono); letter-spacing: 0.04em; }
  /* v2-only: "what Orient creates" object grid */
  .creates { background: var(--paper-2); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .creates .lead-line { font-family: var(--serif); font-size: clamp(20px, 2vw, 24px); color: var(--ink); margin: 18px 0 0; }
  .creates .objects { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 48px; }
  .creates .obj { background: var(--paper); border: 1px solid var(--line); border-radius: 10px; padding: 18px 18px 20px; transition: border-color .15s ease, transform .15s ease; }
  .creates .obj:hover { border-color: var(--line-2); transform: translateY(-2px); }
  .creates .obj .on { font-family: var(--serif); font-size: 19px; letter-spacing: -0.01em; color: var(--ink); }
  .creates .obj .og { font-size: 13.5px; line-height: 1.45; color: var(--ink-2); margin-top: 7px; }
  .creates .obj.machine { border-color: var(--machine-soft); background: var(--machine-soft); }
  .creates .obj.machine .on { color: var(--machine); }
  @media (max-width: 860px) { .creates .objects { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .creates .objects { grid-template-columns: 1fr; } }

  /* v2-only: "how Orient works" flow diagram — delete this block + the matching markup to revert */
  .how .flow { display: grid; grid-template-columns: 1fr auto 1.06fr auto 1fr; align-items: stretch; gap: 0; margin-top: 48px; }
  .how .stage { display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: 16px; background: var(--paper); padding: 24px 22px 26px; }
  .how .stage.orient { background: var(--ink); border-color: var(--ink); align-items: flex-start; box-shadow: 0 14px 40px -22px oklch(0.245 0.012 62 / 0.6); }
  .how .stage .orient-mark { width: 38px; height: 38px; display: block; margin-bottom: 16px; }
  .how .stage-k { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); }
  .how .stage.orient .stage-k { color: oklch(0.95 0.01 84 / 0.6); }
  .how .stage-h { font-family: var(--serif); font-size: clamp(18px, 1.7vw, 21px); line-height: 1.16; letter-spacing: -0.01em; color: var(--ink); margin-top: 8px; }
  .how .stage.orient .stage-h { color: var(--paper-on-ink); }
  .how .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 7px; margin: 18px 0 0; padding: 0; }
  .how .chips li { font-family: var(--mono); font-size: 12px; letter-spacing: 0.01em; color: var(--ink-2); border: 1px solid var(--line); border-radius: 999px; padding: 5px 11px; background: var(--paper); }
  .how .chips.solid li { color: var(--paper-on-ink); border-color: oklch(1 0 0 / 0.18); background: oklch(1 0 0 / 0.07); }
  .how .grp { margin-top: 18px; }
  .how .grp + .grp { margin-top: 16px; }
  .how .grp .chips { margin-top: 9px; }
  .how .grp-l { font-family: var(--mono); font-size: 10.5px; font-weight: 500; letter-spacing: 0.13em; text-transform: uppercase; color: var(--ink-3); }
  .how .grp-l.hu { color: var(--human); }
  .how .grp-l.ma { color: var(--machine); }
  .how .arrow { display: flex; align-items: center; justify-content: center; color: var(--ink-3); width: 52px; }
  .how .arrow svg { width: 26px; height: 26px; }
  @media (max-width: 860px) {
    .how .flow { grid-template-columns: 1fr; }
    .how .arrow { width: auto; padding: 12px 0; }
    .how .arrow svg { transform: rotate(90deg); }
  }

  /* ===== HERO NETWORK — hero background only; delete this block + the matching markup + <script> to revert ===== */
  .hero { position: relative; isolation: isolate; }
  /* translateZ(0) promotes the canvas to its own compositing layer so Chrome paints the
     hero content on first load (fixes a deferred-paint bug that left the hero blank until scroll). */
  .hero-net { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; transform: translateZ(0); will-change: transform; }
  .hero-net-scrim { position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background: radial-gradient(72% 68% at 50% 40%, var(--paper) 0%, var(--paper) 10%, transparent 70%); }
  .hero > .wrap, .hero > .dual-strip { position: relative; z-index: 2; }
  /* ===== end HERO NETWORK ===== */
</style>
<SiteScripts />
</head>
<body>

<!-- ============ HEADER ============ -->
<header class="site-header" id="header">
  <div class="wrap bar">
    <a href="#top" class="brand" aria-label="Orient — home">
      <img src="/logo.svg" alt="Orient" class="brand-logo" />
    </a>
    <nav class="site-nav">
      <a href="#top" aria-current="page" style="color:var(--ink)">What is Orient</a>
      <a href="/forhumans">For Humans</a>
      <a href="/formachines">For Machines</a>
      <a href="/usecases">Use cases</a>
      <a href="/about">About</a>
    </nav>
    <button class="btn" data-scroll="#waitlist">Join waitlist</button>
  </div>
</header>

<main id="top">

  <!-- ============ HERO ============ -->
  <section class="hero">
    <!-- ===== HERO NETWORK — delete this block + the matching <style> + <script> to revert ===== -->
    <canvas class="hero-net" aria-hidden="true"></canvas>
    <div class="hero-net-scrim" aria-hidden="true"></div>
    <!-- ===== end HERO NETWORK ===== -->
    <div class="wrap">
      <span class="eyebrow">The meaning layer</span>
      <h1>The meaning layer for humans <em>and</em> machines</h1>
      <p class="lede">Orient makes <b>meaning</b> from the work people and AI tools create — turning documents, meetings, research, questions, framed communications, and outputs into <b>trusted answers, evidence, memory, and machine-ready context</b>.</p>
      <p class="lede" style="margin-top:16px">So people and agents can act from <b>the same understanding</b>.</p>
      <div class="cta">
        <form class="waitlist" data-waitlist>
          <input type="email" name="email" placeholder="you@company.com" aria-label="Work email" required />
          <button class="btn" type="submit">Join waitlist</button>
        </form>
      </div>
    </div>
    <div class="dual-strip">
      <div class="cell h">
        <div class="tag">FOR HUMANS</div>
        <p>Understand, decide, explain and remember what matters.</p>
      </div>
      <div class="cell m">
        <div class="tag">FOR MACHINES</div>
        <p>Structured meaning, evidence and constraints agents can act on.</p>
      </div>
    </div>
  </section>

  <!-- ============ THESIS / THE SHIFT ============ -->
  <section class="section thesis reveal">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">The shift</span>
        <p class="big">Orient has two customers of meaning. Humans use it to <span class="hu">think and communicate</span>. Agents use it to <span class="ma">act</span>.</p>
      </div>

      <div class="rows">
        <div class="col old">
          <div class="lbl">The old software bet</div>
          <div class="txt">Help people produce more: slides, summaries, memos, research.</div>
        </div>
        <div class="col new">
          <div class="lbl">The new AI-era bet</div>
          <div class="txt">Help humans and agents act from the same resolved meaning.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ DUAL STORY (literal split → two doors) ============ -->
  <section class="split" id="overview">
    <div class="pane h">
      <div class="inner reveal">
        <div class="role">FOR HUMANS</div>
        <h3>Turn what a team knows and thinks into meaning.</h3>
        <p class="verb">Bring anything in — documents, links, meetings, research, raw thought — and move from uncertainty to a defensible answer you can stand behind and share.</p>
        <a href="/forhumans" class="door">
          See Orient for Humans
          <svg viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <div class="pane m">
      <div class="inner reveal">
        <div class="role">FOR MACHINES</div>
        <h3>The structured meaning agents need to act.</h3>
        <p class="verb">Agents don't need a pile of documents. They need to know what is true, uncertain, supported, contradicted, stale — and what they're allowed to say. Orient gives them that.</p>
        <a href="/formachines" class="door">
          See Orient for Machines
          <svg viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ HOW ORIENT WORKS (flow diagram) ============ -->
  <section class="section how reveal" id="how">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">How Orient works</span>
        <h2>From the work you create to meaning you can act on.</h2>
        <p>People and AI tools generate more work than ever. Orient turns it into meaning — legible to the people who decide and the agents that act.</p>
      </div>

      <div class="flow">
        <!-- Stage 1 — inputs -->
        <div class="stage in">
          <div class="stage-k">What goes in</div>
          <div class="stage-h">People &amp; AI tools create work</div>
          <ul class="chips">
            <li>Documents</li>
            <li>Notes</li>
            <li>Pasted text</li>
            <li>Web pages</li>
            <li>Videos</li>
            <li>Voice notes</li>
            <li>Screen recordings</li>
            <li>Meetings</li>
            <li>Chats</li>
            <li>Research</li>
            <li>Web data</li>
            <li>Spreadsheets</li>
            <li>AI chats</li>
            <li>Google Drive</li>
            <li>Notion</li>
            <li>Slack</li>
            <li>SharePoint</li>
            <li>OneDrive</li>
            <li>Dropbox</li>
            <li>Box</li>
            <li>Zoom</li>
            <li>Teams</li>
            <li>Loom</li>
            <li>Salesforce</li>
            <li>HubSpot</li>
            <li>Jira / Linear</li>
          </ul>
        </div>

        <div class="arrow" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><path d="M5 14h16M16 8l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- Stage 2 — Orient -->
        <div class="stage orient">
          <svg class="orient-mark" viewBox="0 0 44 44" aria-hidden="true">
            <path d="M22 3 L3 22 L22 41 Z" fill="var(--human)"/>
            <path d="M22 3 L41 22 L22 41 Z" fill="var(--machine)"/>
            <path d="M22 3 L41 22 L22 41 L3 22 Z" fill="none" stroke="var(--paper-on-ink)" stroke-width="1.4"/>
          </svg>
          <div class="stage-k">What Orient does</div>
          <div class="stage-h">Makes the meaning legible</div>
          <ul class="chips solid">
            <li>Claims</li>
            <li>Evidence</li>
            <li>Provenance</li>
            <li>Contradictions</li>
            <li>Weak spots</li>
            <li>Open probes</li>
            <li>Answers</li>
            <li>Decisions</li>
            <li>Frames</li>
            <li>Topics</li>
            <li>People &amp; context</li>
            <li>Comprehension</li>
            <li>Memory</li>
            <li>Confidence</li>
            <li>Freshness</li>
            <li>Constraints</li>
            <li>Safe-to-act context</li>
          </ul>
        </div>

        <div class="arrow" aria-hidden="true">
          <svg viewBox="0 0 28 28" fill="none"><path d="M5 14h16M16 8l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- Stage 3 — outputs -->
        <div class="stage out">
          <div class="stage-k">What comes out</div>
          <div class="stage-h">People &amp; machines act from it</div>
          <div class="grp">
            <div class="grp-l hu">Frames to communicate</div>
            <ul class="chips">
              <li>Decks</li>
              <li>Memos</li>
              <li>Explainers</li>
              <li>Podcasts</li>
              <li>Videos</li>
              <li>Training</li>
              <li>Q&amp;A</li>
            </ul>
          </div>
          <div class="grp">
            <div class="grp-l ma">Trusted understanding</div>
            <ul class="chips">
              <li>Answers</li>
              <li>Briefings</li>
              <li>Alignment</li>
              <li>Memory</li>
              <li>Agent context</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WHAT ORIENT CREATES ============ -->
  <section class="section creates" id="creates">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">What Orient creates</span>
        <h2>Meaning you can point to.</h2>
        <p class="lead-line">Orient turns work into meaning objects.</p>
        <p>Every document, question, meeting, frame and conversation becomes structured understanding — the same objects people trust and agents can act on.</p>
      </div>

      <div class="objects reveal">
        <div class="obj"><div class="on">Trusted answers</div><div class="og">the current, defensible answer to a real question</div></div>
        <div class="obj"><div class="on">Claims</div><div class="og">the individual assertions in play</div></div>
        <div class="obj"><div class="on">Evidence</div><div class="og">what supports — or weakens — each claim</div></div>
        <div class="obj"><div class="on">Contradictions</div><div class="og">where sources and people disagree</div></div>
        <div class="obj"><div class="on">Open probes</div><div class="og">the questions still being worked</div></div>
        <div class="obj"><div class="on">Frames</div><div class="og">meaning shaped for an audience — decks, memos, briefs</div></div>
        <div class="obj"><div class="on">Decisions</div><div class="og">what was settled, and why</div></div>
        <div class="obj"><div class="on">Topics</div><div class="og">living maps of ideas, built from claims</div></div>
        <div class="obj"><div class="on">People &amp; context</div><div class="og">who knows what, drawn from real work</div></div>
        <div class="obj"><div class="on">Comprehension</div><div class="og">whether the meaning actually landed</div></div>
        <div class="obj"><div class="on">Memory</div><div class="og">what mattered, and how understanding changed</div></div>
        <div class="obj machine"><div class="on">Machine-ready context</div><div class="og">safe-to-act meaning for the agents alongside you</div></div>
      </div>
    </div>
  </section>

  <!-- ============ MOAT QUOTE ============ -->
  <section class="section moat reveal">
    <div class="wrap">
      <blockquote>Making the work was never the hard part. <span class="em">Trusting it</span> is.</blockquote>
      <div class="src">ANYONE CAN GENERATE A DECK — KNOWING IT'S TRUE, CLEAR AND UNDERSTOOD IS THE WORK</div>
    </div>
  </section>

  <!-- ============ CLOSING CTA ============ -->
  <section class="closing" id="waitlist">
    <div class="wrap">
      <img src="/logomark.svg" alt="" class="closing-mark" />
      <h2>Work from the same understanding.</h2>
      <p>Orient is the meaning layer beneath your team and its agents — one resolved source of what's true, decided and safe to act on. Join the waitlist for early access.</p>
      <form class="waitlist onink" data-waitlist style="justify-content:center">
        <input type="email" name="email" placeholder="you@company.com" aria-label="Work email" required />
        <button class="btn" type="submit">Join waitlist</button>
      </form>
    </div>
  </section>
</main>

<!-- ============ FOOTER ============ -->
<Newsletter />
<footer class="site-footer">
  <div class="wrap row">
    <a href="#top" class="brand" aria-label="Orient — home">
      <img src="/logo-light.svg" alt="Orient" class="brand-logo footer-logo" />
    </a>
    <div class="line">The meaning layer for humans and machines.</div>
    <div class="links">
      <a href="#top">What is Orient</a>
      <a href="/forhumans">For Humans</a>
      <a href="/formachines">For Machines</a>
      <a href="/usecases">Use cases</a>
      <a href="/about">About</a>
    </div>
  </div>
</footer>

<script is:inline src="/landing.js"></script>

<!-- ===== HERO NETWORK — delete this block + the matching <style> + markup to revert ===== -->
<script>
(function () {
  var hero = document.querySelector('.hero');
  var canvas = document.querySelector('.hero-net');
  if (!hero || !canvas || !canvas.getContext) return;
  var ctx = canvas.getContext('2d');
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var cs = getComputedStyle(canvas);
  var human = (cs.getPropertyValue('--human') || '').trim() || '#B85C38';
  var machine = (cs.getPropertyValue('--machine') || '').trim() || '#3F6CC4';
  var ink = (cs.getPropertyValue('--ink') || '').trim() || '#262017';
  var dpr = Math.min(window.devicePixelRatio || 1, 2);
  var w = 0, h = 0, nodes = [], raf = null, CONN = 165;

  function size() {
    var r = hero.getBoundingClientRect();
    w = r.width; h = r.height;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    init();
  }
  function init() {
    var count = Math.min(Math.floor((w * h) / 16000), 70);
    nodes = [];
    for (var i = 0; i < count; i++) {
      var x = Math.random() * w;
      nodes.push({
        x: x, y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.22, vy: (Math.random() - 0.5) * 0.22,
        r: Math.random() * 1.8 + 1.4,
        c: x < w / 2 ? human : machine
      });
    }
  }
  function frame() {
    ctx.clearRect(0, 0, w, h);
    ctx.lineWidth = 0.6; ctx.strokeStyle = ink;
    for (var i = 0; i < nodes.length; i++) {
      var p = nodes[i];
      for (var j = i + 1; j < nodes.length; j++) {
        var q = nodes[j], dx = p.x - q.x, dy = p.y - q.y, d = Math.sqrt(dx * dx + dy * dy);
        if (d < CONN) {
          ctx.globalAlpha = (1 - d / CONN) * 0.20;
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(q.x, q.y); ctx.stroke();
        }
      }
    }
    for (var k = 0; k < nodes.length; k++) {
      var n = nodes[k];
      ctx.globalAlpha = 0.62; ctx.fillStyle = n.c;
      ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2); ctx.fill();
    }
    ctx.globalAlpha = 1;
  }
  function step() {
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      n.x += n.vx; n.y += n.vy;
      if (n.x < 0 || n.x > w) n.vx *= -1;
      if (n.y < 0 || n.y > h) n.vy *= -1;
    }
    frame();
    raf = requestAnimationFrame(step);
  }
  function start() { if (raf == null && !reduce) raf = requestAnimationFrame(step); }
  function stop() { if (raf != null) { cancelAnimationFrame(raf); raf = null; } }

  size();
  frame(); // paint an initial frame immediately so Chrome composites the hero layer on load
  if (!reduce && 'IntersectionObserver' in window) {
    new IntersectionObserver(function (es) {
      es.forEach(function (e) { e.isIntersecting ? start() : stop(); });
    }).observe(hero);
  } else if (!reduce) {
    start();
  }
  // re-measure once fonts/layout settle so the canvas matches the final hero height
  window.addEventListener('load', function () {
    stop(); size(); reduce ? frame() : start();
  });
  var rt;
  window.addEventListener('resize', function () {
    clearTimeout(rt);
    rt = setTimeout(function () { stop(); size(); reduce ? frame() : start(); }, 180);
  });
})();
</script>
<!-- ===== end HERO NETWORK ===== -->
</body>
</html>
