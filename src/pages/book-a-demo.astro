---
export const prerender = true;
import SiteScripts from '../components/SiteScripts.astro';
import Newsletter from '../components/Newsletter.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Book a Demo — Orient</title>
<meta name="description" content="See how Orient turns your team's work into trusted, machine-ready meaning. Pick a time that suits you." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/orient.css" />
<link rel="stylesheet" href="/landing.css" />
<style>
  .bd-hero { padding: 110px 0 8px; text-align: center; }
  .bd-hero .eyebrow { display: block; margin-bottom: 18px; }
  .bd-hero h1 { font-size: clamp(36px, 5vw, 56px); line-height: 1.04; letter-spacing: -0.02em; max-width: 18ch; margin: 0 auto; }
  .bd-hero p { font-size: 18px; color: var(--ink-2); margin: 20px auto 0; max-width: 52ch; line-height: 1.55; }
  .bd-embed-wrap { padding: 40px 0 96px; }
  .meetings-iframe-container { max-width: 900px; margin: 0 auto; min-height: 680px; }
</style>

{import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

<SiteScripts />
</head>
<body>

<!-- ============ HEADER ============ -->
<header class="site-header" id="header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="Orient — home">
      <img src="/logo.svg" alt="Orient" class="brand-logo" />
    </a>
    <nav class="site-nav">
      <a href="/">What is Orient</a>
      <a href="/forhumans">For Humans</a>
      <a href="/formachines">For Machines</a>
      <a href="/usecases">Use cases</a>
      <a href="/about">About</a>
    </nav>
    <a class="btn" href="/request-access">Request access</a>
  </div>
</header>

<main id="top">
  <section class="bd-hero">
    <div class="wrap">
      <span class="eyebrow">Talk to us</span>
      <h1>Book a demo</h1>
      <p>See how Orient turns your team's work into trusted answers, evidence, and machine-ready context. Pick a time that suits you.</p>
    </div>
  </section>

  <section class="bd-embed-wrap">
    <div class="wrap">
      <div
        class="meetings-iframe-container"
        data-src="https://meetings-eu1.hubspot.com/mikael16?embed=true"
      ></div>
    </div>
  </section>
</main>

<!-- ============ FOOTER ============ -->
<Newsletter />
<footer class="site-footer">
  <div class="wrap row">
    <a href="/" class="brand" aria-label="Orient — home">
      <img src="/logo-light.svg" alt="Orient" class="brand-logo footer-logo" />
    </a>
    <div class="line">The meaning layer for humans and machines.</div>
    <div class="links">
      <a href="/">What is Orient</a>
      <a href="/request-access">Request access</a>
      <a href="/book-a-demo">Book a demo</a>
      <a href="/about">About</a>
    </div>
  </div>
</footer>

<script is:inline src="/landing.js"></script>
<script is:inline src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js"></script>
</body>
</html>
