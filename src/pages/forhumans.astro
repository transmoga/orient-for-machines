                <path d="M204 133 L650 197"/><path d="M398 133 L650 197"/><path d="M592 133 L650 197"/>
                <path d="M204 197 L650 197"/><path d="M398 197 L650 197"/><path d="M592 197 L650 197"/>
                <path d="M204 261 L650 197"/><path d="M398 261 L650 197"/><path d="M592 261 L650 197"/>
                <path d="M204 325 L650 197"/><path d="M398 325 L650 197"/><path d="M592 325 L650 197"/>
              </g>
