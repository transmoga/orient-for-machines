---
export const prerender = true;
import SiteScripts from '../components/SiteScripts.astro';
import Newsletter from '../components/Newsletter.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Orient for Humans — a thinking space for teams</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/orient.css" />
<link rel="stylesheet" href="/landing.css" />
<link rel="stylesheet" href="/humans.css" />

{import.meta.env.PUBLIC_GA_MEASUREMENT_ID && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

<SiteScripts />
</head>
<body class="h-page">

<!-- ============ HEADER ============ -->
<header class="site-header" id="header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="Orient — home">
      <img src="/logo.svg" alt="Orient" class="brand-logo" />
    </a>
    <nav class="site-nav">
      <a href="/">What is Orient</a>
      <a href="#top" aria-current="page" style="color:var(--ink)">For Humans</a>
      <a href="/formachines">For Machines</a>
      <a href="/usecases">Use cases</a>
      <a href="/about">About</a>
    </nav>
    <button class="btn" data-scroll="#waitlist">Join waitlist</button>
  </div>
</header>

<main id="top">

  <!-- ============ HERO (calm paper) ============ -->
  <section class="h-hero">
    <div class="wrap grid">
      <div>
        <span class="eyebrow">For Humans · The thinking &amp; communicating space</span>
        <h1>A thinking and communicating space for <em>teams</em>.</h1>
          <p class="lede">Orient brings together the knowledge, communication, strategy, and questions inside a team — then turns them into clear answers, supported narratives, and shared understanding.</p>
          <p class="lede lede-close">It helps teams see what is known, what is weak, what is contested, what remains open, what people understand, and what is ready to move forward.</p>
        <div class="cta">
          <button class="btn" data-scroll="#waitlist">Join waitlist</button>
          <a href="#loop" class="ghost">See the loop</a>
        </div>
      </div>
      <div class="reveal in">
        <div class="qstack">
          <div class="q">What is true?</div>
          <div class="q mut">What is supported?</div>
          <div class="q">What's contested?</div>
          <div class="q mut">What have we decided?</div>
          <div class="q">What do people understand?</div>
          <div class="q mut">What needs to be communicated?</div>
          <div class="q">What is ready to move forward?</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SHOWCASE (big product shot) ============ -->
  <section class="section showcase">
    <div class="wrap">
      <figure class="ph uc-shot uc-lead reveal">
        <div class="ph-box">
          <img src="screenshots/hero-screen.png" alt="The Orient thinking space — Activity home with the rolling Fast Read brief, recent frames and active resolves" />
        </div>
        <figcaption class="ph-cap" style="margin-top:16px">A team's knowledge, questions and framed work — resolved in one space.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ PROBLEM (ink) ============ -->
  <section class="section problem">
    <div class="wrap">
      <p class="lead reveal">Modern teams don't lack information. <span class="mut">They have too much of it.</span> The hard part is no longer finding material — it's knowing <span class="hl">what it means</span>.</p>
      <p class="sub reveal">Documents, meetings, links, notes, research, decks, decisions and half-formed ideas, spread across too many tools. Orient gives teams a place to think it through.</p>
    </div>
  </section>

  <!-- ============ CORE LOOP ============ -->
  <section class="section" id="loop">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow clay">The core loop</span>
        <h2>From raw material to shared understanding.</h2>
        <p>Orient is built around a simple loop. Every turn through it leaves the team knowing more — and knowing it together.</p>
      </div>

      <div class="loop reveal">
        <div class="loop-step">
          <div class="n">01</div><h4>Capture</h4>
          <p>Bring scattered material into one place, ready to work with.</p>
          <svg class="arrow" viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="loop-step">
          <div class="n">02</div><h4>Resolve</h4>
          <p>Turn a real question into a defensible answer.</p>
          <svg class="arrow" viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="loop-step">
          <div class="n">03</div><h4>Frame</h4>
          <p>Shape understanding into something others can use.</p>
          <svg class="arrow" viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="loop-step">
          <div class="n">04</div><h4>Measure</h4>
          <p>Check whether the work is clear, supported and ready to move people.</p>
          <svg class="arrow" viewBox="0 0 18 18" fill="none"><path d="M5 3l7 6-7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="loop-step">
          <div class="n">05</div><h4>Remember</h4>
          <p>Hold on to what mattered, and how it changed.</p>
        </div>
      </div>
      <div class="loop-note">
        <svg viewBox="0 0 24 24" fill="none"><path d="M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Remember feeds back into Capture — understanding compounds.
      </div>
    </div>
  </section>

  <!-- ============ CORE ACTIONS, EXPANDED ============ -->
  <section class="section" id="actions" style="background:var(--paper-2);border-top:1px solid var(--line)">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow clay">The creative core</span>
        <h2>Three moves, from material to message.</h2>
      </div>

      <div style="margin-top:34px">
        <div class="action reveal">
          <div class="idx">01</div>
          <div>
            <h3>Capture</h3>
            <p class="desc">Paste a link, upload a document, add a note, record a voice memo, search the web, or pull from connected tools. Orient reads the material and <em>extracts what matters</em> — claims, evidence, concepts, contradictions, decisions and open questions. <b>Capture isn't storage; it's the beginning of understanding.</b></p>
            <div class="meta">
              <div class="meta-title">Drop anything in</div>
              <div class="inputs">
                <span class="input-chip">links</span><span class="input-chip">documents</span><span class="input-chip">notes</span><span class="input-chip">voice memos</span><span class="input-chip">web research</span><span class="input-chip">transcripts</span><span class="input-chip">media</span><span class="input-chip">datasets</span><span class="input-chip">imports</span>
              </div>
            </div>
          </div>
          <figure class="cap-diagram reveal" role="img" aria-label="Anything you drop in — links, documents, notes, voice memos, web research, transcripts, media, datasets and imports — flows into Orient, which reads it and extracts structured meaning: claims, evidence, concepts, contradictions, decisions and open questions.">
            <svg viewBox="0 0 600 420" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <marker id="cdArrow" markerWidth="11" markerHeight="11" refX="6.5" refY="5" orient="auto" markerUnits="userSpaceOnUse">
                  <path d="M1.5,1.5 L8,5 L1.5,8.5" fill="none" stroke="var(--ink-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </marker>
              </defs>

              <!-- inputs -->
              <text x="92" y="96" text-anchor="middle" class="cd-title">Drop anything in</text>
              <g class="cd-badge"><rect x="14" y="119" width="156" height="30" rx="9"/><text x="92" y="139" text-anchor="middle" class="cd-in">Links · Documents</text></g>
              <g class="cd-badge"><rect x="14" y="157" width="156" height="30" rx="9"/><text x="92" y="177" text-anchor="middle" class="cd-in">Notes · Voice memos</text></g>
              <g class="cd-badge"><rect x="14" y="195" width="156" height="30" rx="9"/><text x="92" y="215" text-anchor="middle" class="cd-in">Web · Transcripts</text></g>
              <g class="cd-badge"><rect x="14" y="233" width="156" height="30" rx="9"/><text x="92" y="253" text-anchor="middle" class="cd-in">Media · Datasets</text></g>
              <g class="cd-badge"><rect x="14" y="271" width="156" height="30" rx="9"/><text x="92" y="291" text-anchor="middle" class="cd-in">Imports</text></g>

              <!-- inputs -> core -->
              <line class="cd-conn cd-conn-in" x1="176" y1="210" x2="244" y2="210" marker-end="url(#cdArrow)"/>
              <g class="cd-flow">
                <circle r="3.6" cy="210" fill="var(--human)"><animate attributeName="cx" values="180;242" dur="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.18;0.82;1" dur="2s" repeatCount="indefinite"/></circle>
                <circle r="3.6" cy="210" fill="var(--human)"><animate attributeName="cx" values="180;242" dur="2s" begin="-0.66s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.18;0.82;1" dur="2s" begin="-0.66s" repeatCount="indefinite"/></circle>
                <circle r="3.6" cy="210" fill="var(--human)"><animate attributeName="cx" values="180;242" dur="2s" begin="-1.33s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.18;0.82;1" dur="2s" begin="-1.33s" repeatCount="indefinite"/></circle>
              </g>

              <!-- core -->
              <circle class="cd-ring" cx="316" cy="210" r="84"/>
              <circle class="cd-core" cx="316" cy="210" r="68"/>
              <text x="316" y="206" text-anchor="middle" class="cd-core-t">Reads &amp;</text>
              <text x="316" y="224" text-anchor="middle" class="cd-core-t">extracts</text>

              <!-- core -> meaning objects (curves approach each tag horizontally) -->
              <path class="cd-conn" d="M384 210 C 430 210, 426 65, 462 65"/>
              <path class="cd-conn" d="M384 210 C 430 210, 426 123, 462 123"/>
              <path class="cd-conn" d="M384 210 C 430 210, 426 181, 462 181"/>
              <path class="cd-conn" d="M384 210 C 430 210, 426 241, 462 241"/>
              <path class="cd-conn" d="M384 210 C 430 210, 426 299, 462 299"/>
              <path class="cd-conn" d="M384 210 C 430 210, 426 357, 462 357"/>

              <g class="cd-flow">
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" repeatCount="indefinite"/><animate attributeName="cy" values="210;65" dur="2.2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" repeatCount="indefinite"/></circle>
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" begin="-0.4s" repeatCount="indefinite"/><animate attributeName="cy" values="210;123" dur="2.2s" begin="-0.4s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" begin="-0.4s" repeatCount="indefinite"/></circle>
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" begin="-0.8s" repeatCount="indefinite"/><animate attributeName="cy" values="210;181" dur="2.2s" begin="-0.8s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" begin="-0.8s" repeatCount="indefinite"/></circle>
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" begin="-1.2s" repeatCount="indefinite"/><animate attributeName="cy" values="210;241" dur="2.2s" begin="-1.2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" begin="-1.2s" repeatCount="indefinite"/></circle>
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" begin="-1.6s" repeatCount="indefinite"/><animate attributeName="cy" values="210;299" dur="2.2s" begin="-1.6s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" begin="-1.6s" repeatCount="indefinite"/></circle>
                <circle r="3.2" fill="var(--human)"><animate attributeName="cx" values="392;460" dur="2.2s" begin="-2s" repeatCount="indefinite"/><animate attributeName="cy" values="210;357" dur="2.2s" begin="-2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.15;0.85;1" dur="2.2s" begin="-2s" repeatCount="indefinite"/></circle>
              </g>

              <!-- meaning objects -->
              <text x="470" y="38" class="cd-title">Structured meaning</text>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="50" width="124" height="30" rx="15"/><text x="532" y="70" text-anchor="middle" class="cd-out">claims</text></g>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="108" width="124" height="30" rx="15"/><text x="532" y="128" text-anchor="middle" class="cd-out">evidence</text></g>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="166" width="124" height="30" rx="15"/><text x="532" y="186" text-anchor="middle" class="cd-out">concepts</text></g>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="226" width="124" height="30" rx="15"/><text x="532" y="246" text-anchor="middle" class="cd-out">contradictions</text></g>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="284" width="124" height="30" rx="15"/><text x="532" y="304" text-anchor="middle" class="cd-out">decisions</text></g>
              <g class="cd-out-row"><rect class="cd-tag" x="470" y="342" width="124" height="30" rx="15"/><text x="532" y="362" text-anchor="middle" class="cd-out">open questions</text></g>
            </svg>
          </figure>
        </div>

        <div class="action fig-lg reveal">
          <div class="idx">02</div>
          <div>
            <h3>Resolve</h3>
            <p class="desc">Where a real question becomes a <em>defensible answer</em>. Orient works through the sources, drafts an answer, and shows what holds up — giving teams something more valuable than a summary: <b>a live boundary between knowledge and uncertainty.</b></p>
            <div class="meta">
              <div class="meta-title">It separates</div>
              <div class="states">
                <div class="state s1"><span class="dot"></span><span class="nm">Resolved answers</span><span class="gl">safe to build on</span></div>
                <div class="state s2"><span class="dot"></span><span class="nm">Open probes</span><span class="gl">still being worked</span></div>
                <div class="state s3"><span class="dot"></span><span class="nm">Weak claims</span><span class="gl">need more support</span></div>
                <div class="state s4"><span class="dot"></span><span class="nm">Contested</span><span class="gl">sources disagree</span></div>
                <div class="state s5"><span class="dot"></span><span class="nm">Stale</span><span class="gl">true once, check again</span></div>
              </div>
            </div>
          </div>
          <div class="shot">
            <div class="shot-bar"><i></i><i></i><i></i><span class="url">orient.app / resolve</span></div>
            <img class="shot-img" src="screenshots/resolve-alt.png" alt="Resolve view — a question resolved into a current answer, showing sources read, support points and weak spots" />
          </div>
        </div>

        <div class="action reveal">
          <div class="idx">03</div>
          <div>
            <h3>Frame</h3>
            <p class="desc">Once a question is resolved, Orient helps shape it into something others can use. Frame is the bridge from <em>“we figured this out”</em> to <em>“here's what the audience sees”</em> — and it carries the evidence with the message, so <b>communication stays connected to meaning</b> instead of becoming polished drift.</p>
            <div class="meta">
              <div class="meta-title">A resolved answer becomes</div>
              <div class="outputs">
                <span class="output">a deck</span><span class="output">a briefing</span><span class="output">an article</span><span class="output">a podcast</span><span class="output">a capsule</span><span class="output">flashcards</span><span class="output">a memo</span><span class="output">a narrative</span>
              </div>
            </div>
          </div>
          <div class="shot">
            <div class="shot-bar"><i></i><i></i><i></i><span class="url">orient.app / frame</span></div>
            <img class="shot-img" src="screenshots/screenshot-4-web.png" alt="Frame view — a resolved answer being shaped into a deck or briefing" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MEASURE & REMEMBER ============ -->
  <section class="section" id="close-loop">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow clay">Evaluation &amp; memory</span>
        <h2>Measure what it's worth. Remember what mattered.</h2>
        <p>Making the work is only half the loop. Orient checks whether it's strong enough to move people — then holds on to what was learned.</p>
      </div>

      <div style="margin-top:34px">
        <div class="action reveal">
          <div class="idx">04</div>
          <div>
            <h3>Measure</h3>
            <p class="desc">Before anything ships, Orient reads the work the way a sharp editor would — what is it claiming, how well is it supported, who is it for, and where will people misunderstand it? Not a vanity grade, but a read on whether the meaning is strong enough to move a decision. <b>The result is a Meaning Health Score and a practical review of what to fix.</b></p>
            <div class="meta">
              <div class="meta-title">It scores</div>
              <div class="outputs">
                <span class="output">clarity</span><span class="output">evidence strength</span><span class="output">narrative coherence</span><span class="output">concept stability</span><span class="output">structural integrity</span><span class="output">audience alignment</span><span class="output">information density</span><span class="output">audience response</span>
              </div>
            </div>
          </div>
          <div class="shot">
            <div class="shot-bar"><i></i><i></i><i></i><span class="url">orient.app / measure</span></div>
            <img class="shot-img" src="screenshots/measure-alt.png" alt="Measure view — a Meaning Health Score with the verdict, weak spots and advisory fixes" />
          </div>
        </div>

        <div class="action reveal">
          <div class="idx">05</div>
          <div>
            <h3>Remember</h3>
            <p class="desc">Nothing good gets lost. Orient keeps what mattered — the answers that held, the evidence behind them, the decisions made, and how understanding changed over time. Not a folder of files, but living memory that feeds the next question. <b>Remember feeds back into Capture, so the team's understanding compounds.</b></p>
            <div class="meta">
              <div class="meta-title">It holds on to</div>
              <div class="outputs">
                <span class="output">resolved answers</span><span class="output">the evidence behind them</span><span class="output">decisions</span><span class="output">what changed</span><span class="output">who knew it</span><span class="output">open questions</span>
              </div>
            </div>
          </div>
          <div class="shot">
            <div class="shot-bar"><i></i><i></i><i></i><span class="url">orient.app / remember</span></div>
            <img class="shot-img" src="screenshots/remember.png" alt="Remember view — the team's living memory of answers, decisions and how understanding changed" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ IMPACT ============ -->
  <section class="section" id="impact" style="background:var(--paper-2);border-top:1px solid var(--line)">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow clay">After it ships</span>
        <h2>See whether your thinking survived contact with other people.</h2>
        <p>Measure scores the work before it goes out. Impact watches what happens after — who understood it, how far it travelled, and where the meaning frayed.</p>
      </div>

      <div style="margin-top:34px">
        <div class="action reveal">
          <div class="idx">06</div>
          <div>
            <h3>Impact</h3>
            <p class="desc">A frame doesn't stop mattering the moment it's shared. Orient follows it into the world — tracking who actually engaged, whether the core message was understood, how it spread across the team, and whether the meaning held or drifted as it travelled. <b>Know whether the idea landed, not just whether it was sent.</b></p>
            <div class="meta">
              <div class="meta-title">It watches</div>
              <div class="states">
                <div class="state s1"><span class="dot"></span><span class="nm">Comprehension</span><span class="gl">did people understand it</span></div>
                <div class="state s2"><span class="dot"></span><span class="nm">Reach</span><span class="gl">who saw and engaged</span></div>
                <div class="state s3"><span class="dot"></span><span class="nm">Clarity</span><span class="gl">where it confused</span></div>
                <div class="state s4"><span class="dot"></span><span class="nm">Speed</span><span class="gl">how fast it travelled</span></div>
                <div class="state s5"><span class="dot"></span><span class="nm">Meaning drift</span><span class="gl">where the message frayed</span></div>
              </div>
            </div>
          </div>
          <div class="shot">
            <div class="shot-bar"><i></i><i></i><i></i><span class="url">orient.app / impact</span></div>
            <img class="shot-img" src="screenshots/impact.png" alt="Impact view — comprehension, reach and meaning drift after a frame goes out" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WORKSPACE GRID ============ -->
  <section class="section" id="workspace">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow clay">The thinking space</span>
        <h2>Everywhere the team's understanding lives.</h2>
        <p>Around the loop sits a thinking space for reasoning across everything you've gathered, watching ideas form, and seeing whether they spread.</p>
      </div>

      <div class="workspace-grid reveal">
        <div class="ws-card"><div class="tag">Ask</div><h4>Ask</h4><p>Conversational reasoning across everything the team has gathered and produced — not just retrieval.</p></div>
        <div class="ws-card"><div class="tag">Activity</div><h4>Activity</h4><p>The home feed of what's moving, with a rolling Fast Read brief so people catch up at a glance.</p></div>
        <div class="ws-card"><div class="tag">Answers</div><h4>Answers</h4><p>The catalog of Resolve work — every question, answer, open probe and what's ready to frame.</p></div>
        <div class="ws-card"><div class="tag">Frames</div><h4>Frames</h4><p>The library of finished communication, with a daily briefing of momentum and top topics.</p></div>
        <div class="ws-card"><div class="tag">Deep Reads</div><h4>Deep Reads</h4><p>Structured editorial briefs of important sources — core claims, evidence, weak spots, implications.</p></div>
        <div class="ws-card"><div class="tag">Topics</div><h4>Topics</h4><p>A living map of ideas as they form, sharpen and collide — built from claims, not tags.</p></div>
