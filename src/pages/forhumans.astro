              <g class="brand-node" transform="translate(24 300)"><rect width="180" height="50" rx="9"/><g transform="translate(16 15)"><path class="neutral-mk" d="M2 3h16v11H8l-4 4v-4H2z"/><circle cx="7" cy="8.5" r="1" fill="var(--ink-3)"/><circle cx="10" cy="8.5" r="1" fill="var(--ink-3)"/><circle cx="13" cy="8.5" r="1" fill="var(--ink-3)"/></g><text x="164" y="29" class="brand-name">Chat sessions</text></g>
