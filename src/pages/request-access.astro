---
export const prerender = true;
import SiteScripts from '../components/SiteScripts.astro';
import Newsletter from '../components/Newsletter.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Request Access — Orient</title>
<meta name="description" content="Tell us a little about your team and we'll be in touch with next steps for getting started with Orient." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/orient.css" />
<link rel="stylesheet" href="/landing.css" />
<style>
  .ra-hero { background: var(--ink); color: var(--paper); padding: 120px 0 64px; text-align: center; }
  .ra-hero .eyebrow { color: oklch(0.7 0.08 252); display: block; margin-bottom: 18px; }
  .ra-hero h1 { font-size: clamp(36px, 5vw, 56px); line-height: 1.04; letter-spacing: -0.02em; color: var(--paper); }
  .ra-hero p { font-size: 18px; color: oklch(0.8 0.01 84); margin: 20px auto 0; max-width: 52ch; line-height: 1.55; }
  .ra-form-wrap { background: var(--ink); padding: 0 0 96px; }
  .ra-card { background: var(--paper); border-radius: 12px; max-width: 720px; margin: 0 auto; padding: 40px; box-shadow: 0 24px 60px rgba(0,0,0,0.18); }
  @media (max-width: 860px) { .ra-card { padding: 24px; } }
</style>
<SiteScripts />
</head>
<body>

<!-- ============ HEADER ============ -->
<header class="site-header" id="header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="Orient — home">
      <img src="/logo.svg" alt="Orient" class="brand-logo" />
    </a>
    <nav class="site-nav">
      <a href="/">What is Orient</a>
      <a href="/forhumans">For Humans</a>
      <a href="/formachines">For Machines</a>
      <a href="/usecases">Use cases</a>
      <a href="/about">About</a>
    </nav>
    <a class="btn" href="/book-a-demo">Book a demo</a>
  </div>
</header>

<main id="top">
  <section class="ra-hero">
    <div class="wrap">
      <span class="eyebrow">Get started</span>
      <h1>Request Access</h1>
      <p>Tell us a little about your team and we'll be in touch with next steps for getting started with Orient.</p>
    </div>
  </section>

  <section class="ra-form-wrap">
    <div class="wrap">
      <div class="ra-card">
        <div id="hubspot-request-access-form"></div>
      </div>
    </div>
  </section>
</main>

<!-- ============ FOOTER ============ -->
<Newsletter />
<footer class="site-footer">
  <div class="wrap row">
    <a href="/" class="brand" aria-label="Orient — home">
      <img src="/logo-light.svg" alt="Orient" class="brand-logo footer-logo" />
    </a>
    <div class="line">The meaning layer for humans and machines.</div>
    <div class="links">
      <a href="/">What is Orient</a>
      <a href="/request-access">Request access</a>
      <a href="/book-a-demo">Book a demo</a>
      <a href="/about">About</a>
    </div>
  </div>
</footer>

<script is:inline src="/landing.js"></script>

<script is:inline>
  (function () {
    var created = false;
    function createHubSpotForm() {
      if (created) return;
      if (!window.hbspt || !window.hbspt.forms) return;
      created = true;
      window.hbspt.forms.create({
        portalId: '148266494',
        formId: '5506452a-7f85-4ab0-bd50-1c0748d62baa',
        region: 'eu1',
        target: '#hubspot-request-access-form',
        onFormSubmitted: function () {
          if (typeof window.orientTrack === 'function') {
            window.orientTrack('generate_lead', {
              form_type: 'hubspot_access_form',
              source_page: 'request-access',
              form_location: 'hubspot_embed',
            });
          }
        },
      });
    }

    var script = document.createElement('script');
    script.src = 'https://js-eu1.hsforms.net/forms/embed/v2.js';
    script.charset = 'utf-8';
    script.onload = createHubSpotForm;
    document.head.appendChild(script);
  })();
</script>
</body>
</html>
